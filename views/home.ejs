<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Dating tips, relationship advice aur love guidance for Indian men. Best dating apps, first date tips, aur relationship success ke secrets.">
  <meta name="keywords" content="dating tips india, relationship advice hindi, love tips for men, best dating apps india, first date tips">
  <title>💕 Dating & Relationship Tips for Indian Men | atolf.xyz</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/blog.css">
  
  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1412261360398184" crossorigin="anonymous"></script>
</head>
<body class="hindi">
  
  <!-- Header -->
  <header class="site-header">
    <div class="container">
      <div class="header-content">
        <a href="/" class="site-logo">💕 atolf</a>
        <div class="lang-toggle">
          <button class="lang-btn" data-lang="hi" onclick="setLanguage('hi')">हिंदी</button>
          <button class="lang-btn active" data-lang="en" onclick="setLanguage('en')">English</button>
        </div>
      </div>
    </div>
  </header>

  <!-- Ad Slot 1 - Right after header/logo -->
  <div class="container">
    <div class="ad-container" style="margin-top: 1rem;">
      <div class="ad-label">Advertisement</div>
      <div class="ad-slot">
        <ins class="adsbygoogle"
             style="display:block; min-height:100px;"
             data-ad-client="ca-pub-1412261360398184"
             data-ad-slot="auto"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
      </div>
    </div>
  </div>

  <!-- Hero Section -->
  <main class="container">
    <section class="hero-section">
      <span class="hero-badge">Guide • 2025</span>
      <h1 class="hero-title">
        <span class="lang-hi">💕 Dating & Relationship Tips</span>
        <span class="lang-en">💕 Dating & Relationship Tips</span>
      </h1>
      <p class="hero-subtitle">
        <span class="lang-hi">Indian men ke liye love, dating aur relationship advice 💖</span>
        <span class="lang-en">Love, dating and relationship advice for Indian men 💖</span>
      </p>
    </section>

    <!-- Ad Slot 2 - Right after H1/Hero Section -->
    <div class="ad-container">
      <div class="ad-label">Advertisement</div>
      <div class="ad-slot">
        <ins class="adsbygoogle"
             style="display:block; min-height:100px;"
             data-ad-client="ca-pub-1412261360398184"
             data-ad-slot="auto"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
      </div>
    </div>

    <!-- Posts Grid -->
    <section class="posts-grid">
      <% 
        const postSlugs = ['best-dating-apps', 'first-date-tips', 'dating-profile-tips', 'conversation-starters', 'relationship-tips'];
        const badges = ['🔥 HOT', '💝 NEW', '📸 TIPS', '💬 VIRAL', '💑 BEST'];
        const excerpts = {
          'best-dating-apps': {
            hi: 'India ke top dating apps ka complete review. Konsa app aapke liye best hai? Tinder vs Bumble vs Hinge...',
            en: 'Complete review of India\'s top dating apps. Which app is best for you? Tinder vs Bumble vs Hinge...'
          },
          'first-date-tips': {
            hi: 'Pehli date pe kya karein, kya na karein? Conversation tips, dress code, aur common mistakes se bachein...',
            en: 'What to do and what not to do on your first date? Conversation tips, dress code, and avoid common mistakes...'
          },
          'dating-profile-tips': {
            hi: 'Aapki profile hi aapka first impression hai. Best bio ideas, photo selection tips, aur profile mistakes...',
            en: 'Your profile is your first impression. Best bio ideas, photo selection tips, and profile mistakes...'
          },
          'conversation-starters': {
            hi: 'Chat kaise start karein? Boring "Hi" se better options, interesting questions, aur reply paane ke tips...',
            en: 'How to start a chat? Better options than boring "Hi", interesting questions, and tips to get replies...'
          },
          'relationship-tips': {
            hi: 'Long-lasting relationship ke secrets, trust building, communication tips, aur common relationship problems...',
            en: 'Secrets of long-lasting relationships, trust building, communication tips, and common relationship problems...'
          }
        };
      %>
      
      <% postSlugs.forEach((slug, index) => { 
        const post = posts[slug];
        if (post) { 
      %>
      <a href="/post/<%= slug %>" class="post-card">
        <div class="post-card-image-container">
          <img src="<%= post.image %>" alt="<%= post.title.en %>" class="post-card-img">
          <span class="featured-badge"><%= badges[index] %></span>
        </div>
        <div class="post-card-content">
          <span class="post-card-number"><%= index + 1 %></span>
          <h2 class="post-card-title">
            <span class="lang-hi"><%= post.title.hi %></span>
            <span class="lang-en"><%= post.title.en %></span>
          </h2>
          <p class="post-card-excerpt">
            <span class="lang-hi"><%= excerpts[slug].hi %></span>
            <span class="lang-en"><%= excerpts[slug].en %></span>
          </p>
          <div class="post-card-meta">
            <span class="read-more">
              <span class="lang-hi">पढ़ें →</span>
              <span class="lang-en">Read More →</span>
            </span>
          </div>
        </div>
      </a>
      <% } }) %>

    </section>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <nav class="footer-links">
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy">Privacy Policy</a>
        </nav>
        <p class="footer-copyright">
          © 2025 <span class="footer-domain">atolf.xyz</span> • Made with 💕 in India
        </p>
      </div>
    </div>
  </footer>

  <!-- Service Worker Check & Redirect Script -->
  <script src="/js/sw-check.js"></script>

  <!-- Initialize AdSense Ads -->
  <script>
    // Initialize all ad slots after page loads
    (function() {
      try {
        var ads = document.querySelectorAll('.adsbygoogle');
        ads.forEach(function() {
          (adsbygoogle = window.adsbygoogle || []).push({});
        });
        console.log('[Ads] Initialized ' + ads.length + ' ad slots');
      } catch (e) {
        console.log('[Ads] AdSense not loaded:', e.message);
      }
    })();
  </script>

  <!-- Language Toggle Script -->
  <script>
    // Check saved language preference
    const savedLang = localStorage.getItem('preferredLang') || 'hi';
    setLanguage(savedLang);
    
    function setLanguage(lang) {
      // Update body class
      document.body.classList.remove('hindi', 'english');
      document.body.classList.add(lang === 'hi' ? 'hindi' : 'english');
      
      // Update toggle buttons
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.remove('active');
        if (btn.dataset.lang === lang) {
          btn.classList.add('active');
        }
      });
      
      // Save preference
      localStorage.setItem('preferredLang', lang);
    }
  </script>
</body>
</html>
